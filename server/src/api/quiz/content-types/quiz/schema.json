{
  "kind": "collectionType",
  "collectionName": "quizzes",
  "info": {
    "singularName": "quiz",
    "pluralName": "quizzes",
    "displayName": "Quiz",
    "description": "Assessments for courses"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "course": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::course.course",
      "inversedBy": "quizzes"
    },
    "passingScore": {
      "type": "integer",
      "default": 70,
      "min": 0,
      "max": 100
    },
    "timeLimit": {
      "type": "integer",
      "description": "Time limit in minutes"
    },
    "questions": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::question.question",
      "mappedBy": "quiz"
    },
    "attempts": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::quiz-attempt.quiz-attempt",
      "mappedBy": "quiz"
    }
  }
}
