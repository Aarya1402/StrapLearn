{
  "kind": "collectionType",
  "collectionName": "notifications",
  "info": {
    "singularName": "notification",
    "pluralName": "notifications",
    "displayName": "Notification",
    "description": "System and user notifications"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    },
    "type": {
      "type": "enumeration",
      "enum": [
        "enrollment",
        "completion",
        "quiz",
        "system",
        "message"
      ],
      "required": true
    },
    "title": {
      "type": "string",
      "required": true
    },
    "message": {
      "type": "text",
      "required": true
    },
    "isRead": {
      "type": "boolean",
      "default": false,
      "required": true
    },
    "link": {
      "type": "string"
    }
  }
}
